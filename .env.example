# Required — bot will not start without these
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Optional — global bot owner (bypasses all admin checks)
DISCORD_APP_OWNER_ID=

# Optional — webhook URL for centralized logging
DISCORD_CONSOLE=

# Optional — required for Linked Roles OAuth2 flow
DISCORD_CLIENT_SECRET=

# Optional — protects admin endpoints (register, discover, invite)
ADMIN_PASSWORD=

# Optional — required for Steam linked-role verifier
STEAM_API_KEY=

# Optional — required for Patreon webhook signature verification
PATREON_WEBHOOK_SECRET=

# Optional — comma-separated guild IDs to restrict the bot to
ALLOWED_GUILD_IDS=
